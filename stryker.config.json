{
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.js"
  },
  "mutate": [
    "kiosk-web/**/*.js",
    "!kiosk-web/**/*.test.js",
    "!kiosk-web/app.js",
    "!kiosk-web/config.js"
  ],
  "ignorePatterns": [
    "backend/**",
    "mobile/**",
    "jukebox-web-controller/**"
  ],
  "reporters": ["html", "clear-text", "progress"],
  "coverageAnalysis": "perTest",
  "concurrency": 4
}